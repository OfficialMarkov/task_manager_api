# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=task_manager
POSTGRES_PORT=5432

# JWT Configuration
